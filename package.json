			"optional": false
		}
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "^0.74.0",
		"@types/node": "^24.7.2",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	}
